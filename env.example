# =====================================================================
# fuel-price-pipeline — example environment file
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# this `.env.example` is committed so anyone cloning the repo knows which
# variables to set. Never commit real secrets.
#
#   cp .env.example .env
# =====================================================================

# ---------------------------------------------------------------------
# EIA API  (required — both Go and C#)
# ---------------------------------------------------------------------
# API key for the U.S. Energy Information Administration (api.eia.gov).
# Request one free at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ---------------------------------------------------------------------
# Database  (PostgreSQL)
# ---------------------------------------------------------------------
# Connection string / DSN for the Postgres instance. Schema/table:
# fuel_price.diesel_fuel_price
#
# Used by: Go (FUEL_DSN) and C# (FUEL_DSN) — both backends read the same var.
FUEL_DSN=postgresql://postgres:postgres@localhost:5432/fuel_price

# ---------------------------------------------------------------------
# CSV output  (C# — optional, have defaults)
# ---------------------------------------------------------------------
# Output path for the latest-prices CSV export. Default: fuel-latest.csv
FUEL_OUT=fuel-latest.csv

# EIA area code to pull. Default: NUS (U.S. national). Examples:
#   NUS = U.S.,  R10 = East Coast (PADD 1),  R30 = Gulf Coast (PADD 3)
FUEL_AREA=NUS

# =====================================================================
# Optional overrides
# =====================================================================
# Address the Go Chi API listens on. Optional — defaults to :8080.
# API_ADDR=:8080
